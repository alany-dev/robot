<?xml version="1.0"?>
<launch>
  <!-- 参数设置 -->
  <arg name="use_sim_time" default="false"/>
  <arg name="scan_topic" default="/scan"/>
  
  <!-- 设置仿真时间 -->
  <param name="use_sim_time" value="$(arg use_sim_time)"/>
  
  <!-- 启动机器人描述 -->
  <include file="$(find test11_description)/launch/display.launch"/>
  
  <!-- 启动base_control节点 -->
  <include file="$(find base_control)/launch/base_control.launch"/>
  
  <!-- 启动激光雷达 -->
  <include file="$(find ydlidar)/launch/ydlidar.launch"/>
  
  <!-- 等待话题准备就绪 -->
  <node pkg="rostopic" type="rostopic" name="wait_for_odom" 
        args="echo -n 1 /odom" output="screen" 
        launch-prefix="bash -c 'sleep 5; exec $0 $@'"/>
  
  <node pkg="rostopic" type="rostopic" name="wait_for_scan" 
        args="echo -n 1 $(arg scan_topic)" output="screen" 
        launch-prefix="bash -c 'sleep 5; exec $0 $@'"/>
  
  <!-- 启动修复后的gmapping -->
  <include file="$(find robot_navigation)/launch/slam/gmapping_fixed.launch">
    <arg name="scan_topic" value="$(arg scan_topic)"/>
  </include>
  
  <!-- 启动RViz -->
  <node pkg="rviz" type="rviz" name="rviz" 
        args="-d $(find robot_navigation)/rviz/slam.rviz" 
        output="screen"/>
        
</launch>

