<?xml version="1.0"?>
<launch>
<node pkg="explore_lite" type="explore" respawn="false" name="explore" output="screen">
  <param name="robot_base_frame" value="base_footprint"/>
  <param name="costmap_topic" value="map"/>
  <param name="costmap_updates_topic" value="map_updates"/> <!--if everytime update full map, do not sub this topic-->
  <param name="visualize" value="true"/>
  <param name="planner_frequency" value="1.0"/> <!--规划频率hz default:1.0-->
  <param name="progress_timeout" value="10.0"/>
  <param name="potential_scale" value="1e-3"/> <!--default:1e-3-->
  <param name="orientation_scale" value="0.0"/>
  <param name="gain_scale" value="1.0"/>
  <param name="transform_tolerance" value="0.3"/>
  <param name="min_frontier_size" value="0.5"/>  <!--最小的未知边界长度，小于这个长度就不会去探索了 default:0.5-->
</node>
</launch>

